# RiskIntel Cloud - copy to .env and set in production
# See docs/architecture/02-cloud-saas-architecture.md

# Database
DATABASE_URL=postgresql://riskintel:riskintel@localhost:5432/riskintel

# Redis (cache, optional queue)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-256-bit-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# SMS (OTP)
SMS_PROVIDER_URL=https://api.sms-provider.example/send
SMS_API_KEY=
SMS_SENDER=

# Sync (edge device auth)
SYNC_TLS_CERT_PATH=/certs/server.crt
SYNC_TLS_KEY_PATH=/certs/server.key
SYNC_CLIENT_CA_PATH=/certs/client-ca.crt

# Port
PORT=8080
